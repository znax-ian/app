{
  "name": "arcsuite-electron",
  "version": "1.0.5",
  "description": "Desktop client for QC tools",
  "license": "MIT",
  "author": "Ian Tsai",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dist": "electron-builder",
    "publish": "electron-builder -p always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/znax-ian/app.git"
  },
  "devDependencies": {
    "electron": "^40.2.1",
    "electron-builder": "^26.8.1",
    "patch-package": "^8.0.1"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "jspreadsheet-ce": "^5.0.4",
    "mssql": "^12.2.0",
    "xml2js": "^0.6.2"
  },
  "build": {
    "appId": "io.github.znax-ian.qc-tools",
    "productName": "QC_Tools",
    "electronLanguages": [
      "en-US",
      "ja"
    ],
    "extraResources": [
      ".env"
    ],
    "files": [
      "**/*",
      "!.vscode${/*}",
      "!.env",
      "!apikey.txt"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "znax-ian",
        "repo": "app"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "images/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
